{
  "name": "@zurb/helio-cli",
  "version": "0.3.0",
  "description": "CLI for the Helio Public API",
  "type": "module",
  "bin": {
    "helio-cli": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/update-check-worker.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
